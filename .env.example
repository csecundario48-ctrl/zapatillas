# Copiá este archivo a .env.local y completá con tus claves de Supabase.
# NUNCA commitees .env.local (ya está en .gitignore).

# URL del proyecto y clave pública (segura para el navegador)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Clave service_role: SOLO servidor. Bypassa RLS. Nunca la expongas al cliente
# ni la subas al repo. La app actual no la necesita para funcionar.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
